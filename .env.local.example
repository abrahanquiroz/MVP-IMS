# =============================================================================
# Local: copia a .env.local y rellena (Project Settings → API en Supabase)
# Producción (Vercel): Project → Settings → Environment Variables
# =============================================================================

# Ejemplo proyecto: https://yaxegheumotfyuduqlfj.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://TU_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_PUBLIC_KEY

# Solo servidor (nunca NEXT_PUBLIC_*). Necesaria para que el cuidador cree cuentas de personas cuidadas.
# Project Settings → API → service_role (secreta). En Vercel: Production + Preview si pruebas altas de paciente.
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY

# Opcional: URL canónica de producción (útil para enlaces en emails de Supabase).
# En Vercel NO es obligatoria para OAuth: el callback usa el host real (incl. previews).
NEXT_PUBLIC_SITE_URL=https://mvp-ims.vercel.app

# Legacy (la app usa window.location.origin en el cliente para OAuth; puedes omitir):
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback

# -----------------------------------------------------------------------------
# Checklist Supabase (Dashboard) para MVP en https://mvp-ims.vercel.app
# -----------------------------------------------------------------------------
#
# 1) Authentication → URL configuration
#    - Site URL: https://mvp-ims.vercel.app
#    - Additional Redirect URLs (añade todas las que uses):
#        https://mvp-ims.vercel.app/auth/callback
#        http://localhost:3000/auth/callback
#        https://*.vercel.app/auth/callback
#
# 2) Authentication → Providers → Google: ON (si está OFF verás "provider is not enabled")
#    - Client ID y Client Secret de Google Cloud Console
#    - En Google Cloud: APIs & Services → Credentials → OAuth 2.0
#      Authorized redirect URI = Callback URL (OAuth) de Supabase, NO la de Vercel:
#        https://yaxegheumotfyuduqlfj.supabase.co/auth/v1/callback
#      (Genérico: https://TU_REF.supabase.co/auth/v1/callback)
#
# 3) Authentication → Providers → Email: ON
#    - Para MVP sin fricción: desactiva "Confirm email" (usuarios entran al instante)
#
# 4) API keys: usa la clave "anon" / "public" (compatible con el cliente JS).
#
# -----------------------------------------------------------------------------
